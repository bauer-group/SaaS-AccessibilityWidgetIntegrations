plugin.tx_bfsgwidget {
  settings {
    # Pfade zu den Asset-Dateien
    loaderPath = EXT:bfsg_widget/Resources/Public/JavaScript/bfsg-widget-loader.min.js
    corePath = EXT:bfsg_widget/Resources/Public/JavaScript/bfsg-widget-core.min.js
    cssPath = EXT:bfsg_widget/Resources/Public/Css/bfsg-widget.min.css

    position = bottom-right
    locale = auto
    primaryColor = #0058a3

    # SRI-Hashes (optional, aus dist/integrity.txt)
    loaderIntegrity =
    coreIntegrity =
    cssIntegrity =
  }
}
