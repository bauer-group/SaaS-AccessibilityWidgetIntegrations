---
interface Props {
  loaderSrc?: string;
  cssHref?: string;
  config?: Record<string, unknown>;
  sri?: { loader?: string; css?: string };
}

const {
  loaderSrc = '/accessibility-widget-loader.min.js',
  cssHref = '/accessibility-widget.min.css',
  config = {},
  sri = {},
} = Astro.props;

const configJson = JSON.stringify(config);
---

<script is:inline define:vars={{ configJson }}>
  try {
    window.AccessibilityWidgetConfig = { ...(window.AccessibilityWidgetConfig ?? {}), ...JSON.parse(configJson) };
  } catch (e) { /* silent */ }
</script>
{cssHref && (
  <link rel="stylesheet" href={cssHref} data-aw-css="1" {...(sri.css ? { integrity: sri.css, crossorigin: 'anonymous' } : {})} />
)}
{loaderSrc && (
  <script src={loaderSrc} defer data-aw-loader="1" {...(sri.loader ? { integrity: sri.loader, crossorigin: 'anonymous' } : {})} />
)}
