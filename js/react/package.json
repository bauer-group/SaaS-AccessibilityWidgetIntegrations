{
  "name": "@bauer-group/accessibility-widget-react",
  "version": "1.0.0-alpha.1",
  "description": "React Wrapper für das BAUER GROUP Accessibility Widget.",
  "license": "MIT",
  "author": "BAUER GROUP <info@de.bauer-group.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@bauer-group/accessibility-widget": "^1.0.0-alpha.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "happy-dom": "^17.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
