<?php
/**
 * @var \Magento\Framework\View\Element\Template $block
 * @var \Magento\Framework\Escaper $escaper
 */

$scopeConfig = $block->getData('scopeConfig')
    ?? \Magento\Framework\App\ObjectManager::getInstance()->get(\Magento\Framework\App\Config\ScopeConfigInterface::class);

$position = (string) ($scopeConfig->getValue('bfsg_widget/settings/position') ?: 'bottom-right');
$locale = (string) ($scopeConfig->getValue('bfsg_widget/settings/locale') ?: 'auto');
$color = (string) ($scopeConfig->getValue('bfsg_widget/settings/primary_color') ?: '#0058a3');

$baseUrl = $block->getViewFileUrl('BauerGroup_BFSGWidget::');
$cfg = [
    'corePath' => $baseUrl . 'bfsg-widget-core.min.js',
    'cssPath' => $baseUrl . 'bfsg-widget.min.css',
    'position' => $position,
    'locale' => $locale,
    'primaryColor' => $color,
];
?>
<script>
  window.BFSGWidgetConfig = <?= /* @noEscape */ json_encode($cfg, JSON_UNESCAPED_SLASHES) ?>;
</script>
<script src="<?= $escaper->escapeUrl($baseUrl . 'bfsg-widget-loader.min.js') ?>" defer data-bfsg="loader"></script>
