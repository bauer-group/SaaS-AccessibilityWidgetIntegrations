{%- comment -%}
  BFSG Accessibility Widget — Shopify snippet
  Usage:
    {% render 'bfsg-widget',
       position: 'bottom-right',
       locale: 'auto',
       primary_color: '#0058a3',
       loader_integrity: '',
       core_integrity: '' %}
{%- endcomment -%}
{%- assign _position = position | default: 'bottom-right' -%}
{%- assign _locale = locale | default: 'auto' -%}
{%- assign _color = primary_color | default: '#0058a3' -%}

<script>
  window.BFSGWidgetConfig = {
    corePath: {{ 'bfsg-widget-core.min.js' | asset_url | json }},
    cssPath: {{ 'bfsg-widget.min.css' | asset_url | json }},
    position: {{ _position | json }},
    locale: {{ _locale | json }},
    primaryColor: {{ _color | json }}
    {%- if core_integrity != blank -%}
    , coreIntegrity: {{ core_integrity | json }}
    {%- endif -%}
  };
</script>
<script src="{{ 'bfsg-widget-loader.min.js' | asset_url }}" defer
  {%- if loader_integrity != blank %} integrity="{{ loader_integrity }}" crossorigin="anonymous"{% endif -%}
  data-bfsg="loader"></script>
