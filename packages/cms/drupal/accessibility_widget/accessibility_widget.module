<?php

/**
 * @file
 * BAUER GROUP Accessibility Widget — Drupal integration.
 *
 * The widget loads from the CDN (floating `v1` tag) and stays current
 * automatically; no assets are bundled. Set "assetBase" in the settings only to
 * self-host or mirror. Every option of window.AccessibilityWidgetConfig is
 * exposed in the settings form, generated from the shared schema
 * (accessibility_widget.fields.php).
 */

declare(strict_types=1);

/**
 * Default CDN origin — the floating `v1` (major) tag.
 */
const ACCESSIBILITY_WIDGET_CDN = 'https://widgets.professional-hosting.com/accessibility-widget/v1';

/**
 * The generated bilingual field descriptors (groups + fields + asset metadata).
 */
function accessibility_widget_fields(): array {
  static $fields = NULL;
  if ($fields === NULL) {
    $fields = require __DIR__ . '/accessibility_widget.fields.php';
  }
  return $fields;
}

/**
 * The active interface language reduced to a shipped catalog ('de' or 'en').
 */
function accessibility_widget_lang(): string {
  $id = \Drupal::languageManager()
    ->getCurrentLanguage(\Drupal\Core\Language\LanguageInterface::TYPE_INTERFACE)
    ->getId();
  return str_starts_with($id, 'de') ? 'de' : 'en';
}

/**
 * TRUE for http/https/mailto/tel or relative URLs; rejects javascript:/data:.
 */
function accessibility_widget_is_safe_url(string $url): bool {
  $scheme = strtolower((string) parse_url($url, PHP_URL_SCHEME));
  return $scheme === '' || in_array($scheme, ['http', 'https', 'mailto', 'tel'], TRUE);
}

/**
 * Assemble window.AccessibilityWidgetConfig from the stored settings.
 */
function accessibility_widget_build_config(): array {
  $config = \Drupal::config('accessibility_widget.settings');
  $schema = accessibility_widget_fields();
  $out = [];
  $offset = [];
  $initial = [];
  $disabled = [];
  $assets = ['base' => '', 'core' => '', 'css' => '', 'coreIntegrity' => '', 'cssIntegrity' => ''];

  foreach ($schema['fields'] as $field) {
    $key = $field['key'];
    $raw = $config->get($key);
    if ($raw === NULL) {
      $raw = $field['default'] ?? '';
    }

    if (!empty($field['asset'])) {
      $assets[$field['asset']] = is_string($raw) ? trim($raw) : '';
      continue;
    }
    if ($field['type'] === 'feature_state') {
      if ($raw === 'on') {
        $initial[$field['feature']] = TRUE;
      }
      elseif ($raw === 'off') {
        $initial[$field['feature']] = FALSE;
      }
      elseif ($raw === 'disabled') {
        $disabled[] = $field['feature'];
      }
      continue;
    }

    switch ($field['type']) {
      case 'bool':
        $value = (bool) $raw;
        break;

      case 'int':
        $value = (int) $raw;
        if (isset($field['min']) && $value < $field['min']) {
          $value = (int) $field['min'];
        }
        break;

      default:
        $value = (string) $raw;
        if (($field['special'] ?? '') === 'keyboardShortcut') {
          $value = $value === '' ? FALSE : $value;
        }
        elseif ($value === '') {
          continue 2;
        }
        elseif (($field['validate'] ?? '') === 'url-safe' && !accessibility_widget_is_safe_url($value)) {
          continue 2;
        }
    }

    if (isset($field['runtimeKey']) && str_starts_with($field['runtimeKey'], 'offset.')) {
      $offset[substr($field['runtimeKey'], 7)] = $value;
    }
    else {
      $out[$key] = $value;
    }
  }

  if ($offset) {
    $out['offset'] = ['x' => $offset['x'] ?? 20, 'y' => $offset['y'] ?? 20];
  }
  if ($initial) {
    $out['initialFeatures'] = $initial;
  }
  if ($disabled) {
    $out['disabledFeatures'] = $disabled;
  }

  $base = $assets['base'] !== '' ? rtrim($assets['base'], '/') : rtrim($schema['cdnBase'], '/');
  $out['corePath'] = $assets['core'] !== '' ? $assets['core'] : $base . '/' . $schema['assetFiles']['core'];
  $out['cssPath'] = $assets['css'] !== '' ? $assets['css'] : $base . '/' . $schema['assetFiles']['css'];
  if ($assets['coreIntegrity'] !== '') {
    $out['coreIntegrity'] = $assets['coreIntegrity'];
  }
  if ($assets['cssIntegrity'] !== '') {
    $out['cssIntegrity'] = $assets['cssIntegrity'];
  }

  return $out;
}

/**
 * Implements hook_page_attachments().
 */
function accessibility_widget_page_attachments(array &$attachments): void {
  $config = \Drupal::config('accessibility_widget.settings');
  $schema = accessibility_widget_fields();

  $base = (string) ($config->get('assetBase') ?: $schema['cdnBase']);
  $base = rtrim($base, '/');

  $json = json_encode(
    accessibility_widget_build_config(),
    JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE
  );

  // JSON_HEX_* escapes every <, >, &, ' and " so the value cannot break out of
  // the <script> element; Markup::create then emits it verbatim (valid JS).
  $attachments['#attached']['html_head'][] = [
    [
      '#type' => 'html_tag',
      '#tag' => 'script',
      '#value' => \Drupal\Core\Render\Markup::create('window.AccessibilityWidgetConfig = ' . $json . ';'),
    ],
    'accessibility_widget_config',
  ];

  $attachments['#attached']['html_head'][] = [
    [
      '#type' => 'html_tag',
      '#tag' => 'script',
      '#attributes' => [
        'src' => $base . '/' . $schema['assetFiles']['loader'],
        'defer' => 'defer',
        'data-aw-loader' => '1',
      ],
    ],
    'accessibility_widget_loader',
  ];
}
