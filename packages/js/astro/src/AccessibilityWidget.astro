---
import type { WidgetConfig } from './widget-config.generated';
import {
  DEFAULT_LOADER_SRC,
  DEFAULT_CORE_SRC,
  DEFAULT_CSS_HREF,
} from './widget-config.generated';

interface Props {
  loaderSrc?: string;
  coreSrc?: string;
  cssHref?: string;
  config?: WidgetConfig;
}

const {
  loaderSrc = DEFAULT_LOADER_SRC,
  coreSrc = DEFAULT_CORE_SRC,
  cssHref = DEFAULT_CSS_HREF,
  config = {},
} = Astro.props;

// The loader can't derive core/CSS from its own <script src>; pin them here.
const configJson = JSON.stringify({ corePath: coreSrc, cssPath: cssHref, ...config });
---

<script is:inline define:vars={{ configJson }}>
  try {
    window.AccessibilityWidgetConfig = {
      ...(window.AccessibilityWidgetConfig ?? {}),
      ...JSON.parse(configJson),
    };
  } catch (e) {
    /* silent */
  }
</script>
{cssHref && <link rel="stylesheet" href={cssHref} data-aw-css="1" />}
{loaderSrc && <script is:inline src={loaderSrc} defer data-aw-loader="1" />}
