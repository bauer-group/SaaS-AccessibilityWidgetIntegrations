{
  "name": "@bauer-group/accessibility-widget-react",
  "version": "2.0.0",
  "description": "React Wrapper für das BAUER GROUP Accessibility Widget.",
  "license": "MIT",
  "author": "BAUER GROUP <info@ge.bauer-group.com>",
  "homepage": "https://github.com/bauer-group/SaaS-AccessibilityWidgetIntegrations/tree/main/packages/js/react",
  "repository": {
    "type": "git",
    "url": "https://github.com/bauer-group/SaaS-AccessibilityWidgetIntegrations.git",
    "directory": "packages/js/react"
  },
  "bugs": {
    "url": "https://github.com/bauer-group/SaaS-AccessibilityWidgetIntegrations/issues"
  },
  "keywords": [
    "react",
    "accessibility",
    "a11y",
    "wcag",
    "bfsg",
    "en301549",
    "widget",
    "bauer-group"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist tsconfig.build.tsbuildinfo"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "happy-dom": "^17.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
