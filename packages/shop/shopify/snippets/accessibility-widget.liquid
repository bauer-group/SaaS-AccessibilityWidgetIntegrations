{%- comment -%}
  BAUER GROUP Accessibility Widget — Shopify snippet
  @version 1.1.1
  Loads from the CDN (floating v1 tag) and stays current automatically.
  Usage:
    {% render 'accessibility-widget',
       position: 'bottom-right',
       locale: 'auto',
       primary_color: '#0058a3',
       cdn_base: '' %}   {%- comment -%} optional: override to self-host/mirror {%- endcomment -%}
{%- endcomment -%}
{%- assign _position = position | default: 'bottom-right' -%}
{%- assign _locale = locale | default: 'auto' -%}
{%- assign _color = primary_color | default: '#0058a3' -%}
{%- assign _base = cdn_base | default: 'https://widgets.professional-hosting.com/accessibility-widget/v1' -%}

<script>
  window.AccessibilityWidgetConfig = {
    corePath: {{ _base | append: '/accessibility-widget-core.min.js' | json }},
    cssPath: {{ _base | append: '/accessibility-widget.min.css' | json }},
    position: {{ _position | json }},
    locale: {{ _locale | json }},
    primaryColor: {{ _color | json }}
  };
</script>
<script src="{{ _base }}/accessibility-widget-loader.min.js" defer data-aw-loader="1"></script>
