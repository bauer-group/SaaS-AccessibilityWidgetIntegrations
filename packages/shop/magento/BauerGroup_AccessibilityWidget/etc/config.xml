<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
  <default>
    <accessibility_widget>
      <appearance>
        <position>bottom-right</position>
        <offsetX>20</offsetX>
        <offsetY>20</offsetY>
        <zIndex>2147483646</zIndex>
        <primaryColor>#0058a3</primaryColor>
        <locale>auto</locale>
      </appearance>
      <behavior>
        <draggableFab>0</draggableFab>
        <respectReducedMotion>1</respectReducedMotion>
        <hideOnPrint>1</hideOnPrint>
        <keyboardShortcut>ctrl+alt+a</keyboardShortcut>
        <storageKey>accessibility-widget</storageKey>
        <hidePoweredBy>0</hidePoweredBy>
        <debug>0</debug>
      </behavior>
      <features>
        <feature_fontSize>default</feature_fontSize>
        <feature_lineHeight>default</feature_lineHeight>
        <feature_letterSpacing>default</feature_letterSpacing>
        <feature_contrast>default</feature_contrast>
        <feature_grayscale>default</feature_grayscale>
        <feature_invertColors>default</feature_invertColors>
        <feature_dyslexiaFont>default</feature_dyslexiaFont>
        <feature_highlightLinks>default</feature_highlightLinks>
        <feature_pauseAnimations>default</feature_pauseAnimations>
        <feature_bigCursor>default</feature_bigCursor>
        <feature_focusOutline>default</feature_focusOutline>
        <feature_readingMask>default</feature_readingMask>
        <feature_readingGuide>default</feature_readingGuide>
        <feature_tts>default</feature_tts>
        <feature_structureNav>default</feature_structureNav>
      </features>
    </accessibility_widget>
  </default>
</config>
