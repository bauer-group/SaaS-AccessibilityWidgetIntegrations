{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{% block layout_head_javascript_tracking %}
  {{ parent() }}

  {# Config is assembled tag-break-safe in StorefrontConfigSubscriber (JSON_HEX_*). #}
  {% if accessibilityWidget is defined %}
    <script>window.AccessibilityWidgetConfig = {{ accessibilityWidget.config|raw }};</script>
    <script src="{{ accessibilityWidget.loader|escape('html_attr') }}" defer data-aw-loader="1"></script>
  {% endif %}
{% endblock %}
