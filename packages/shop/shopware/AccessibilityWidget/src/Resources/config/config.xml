<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
  <card>
    <title>BAUER GROUP Accessibility Widget</title>
    <title lang="de-DE">BAUER GROUP Barrierefreiheits-Widget</title>

    <input-field type="single-select">
      <name>position</name>
      <defaultValue>bottom-right</defaultValue>
      <label>Position</label>
      <options>
        <option><id>bottom-right</id><name>Bottom right</name></option>
        <option><id>bottom-left</id><name>Bottom left</name></option>
        <option><id>top-right</id><name>Top right</name></option>
        <option><id>top-left</id><name>Top left</name></option>
      </options>
    </input-field>

    <input-field type="single-select">
      <name>locale</name>
      <defaultValue>auto</defaultValue>
      <label>Locale</label>
      <options>
        <option><id>auto</id><name>Auto</name></option>
        <option><id>de</id><name>de</name></option>
        <option><id>en</id><name>en</name></option>
        <option><id>fr</id><name>fr</name></option>
        <option><id>es</id><name>es</name></option>
        <option><id>it</id><name>it</name></option>
        <option><id>pl</id><name>pl</name></option>
        <option><id>tr</id><name>tr</name></option>
        <option><id>ar</id><name>ar</name></option>
        <option><id>zh</id><name>zh</name></option>
        <option><id>hi</id><name>hi</name></option>
        <option><id>pt</id><name>pt</name></option>
        <option><id>bn</id><name>bn</name></option>
        <option><id>ru</id><name>ru</name></option>
        <option><id>ja</id><name>ja</name></option>
        <option><id>ko</id><name>ko</name></option>
        <option><id>vi</id><name>vi</name></option>
        <option><id>fa</id><name>fa</name></option>
        <option><id>ur</id><name>ur</name></option>
        <option><id>th</id><name>th</name></option>
        <option><id>id</id><name>id</name></option>
        <option><id>he</id><name>he</name></option>
        <option><id>nl</id><name>nl</name></option>
        <option><id>sv</id><name>sv</name></option>
        <option><id>cs</id><name>cs</name></option>
        <option><id>el</id><name>el</name></option>
        <option><id>hu</id><name>hu</name></option>
        <option><id>ro</id><name>ro</name></option>
        <option><id>uk</id><name>uk</name></option>
      </options>
    </input-field>

    <input-field type="colorpicker">
      <name>primaryColor</name>
      <defaultValue>#0058a3</defaultValue>
      <label>Primärfarbe</label>
    </input-field>
  </card>
</config>
