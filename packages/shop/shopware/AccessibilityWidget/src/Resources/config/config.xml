  <card>
    <title>Behavior</title>
    <title lang="de-DE">Verhalten</title>

    <input-field type="bool">
      <name>draggableFab</name>
      <defaultValue>false</defaultValue>
      <label>Draggable button</label>
      <label lang="de-DE">Verschiebbare Schaltfläche</label>
      <helpText>Let visitors drag the button to reposition it.</helpText>
      <helpText lang="de-DE">Besucher können die Schaltfläche verschieben.</helpText>
    </input-field>

    <input-field type="bool">
      <name>respectReducedMotion</name>
      <defaultValue>true</defaultValue>
      <label>Respect reduced motion</label>
      <label lang="de-DE">„Reduzierte Bewegung“ beachten</label>
      <helpText>Honor the visitor's prefers-reduced-motion setting.</helpText>
      <helpText lang="de-DE">Die Einstellung „prefers-reduced-motion“ des Besuchers berücksichtigen.</helpText>
    </input-field>

    <input-field type="bool">
      <name>hideOnPrint</name>
      <defaultValue>true</defaultValue>
      <label>Hide on print</label>
      <label lang="de-DE">Beim Drucken ausblenden</label>
      <helpText>Hide the widget on printed pages.</helpText>
      <helpText lang="de-DE">Widget in der Druckansicht ausblenden.</helpText>
    </input-field>

    <input-field type="text">
      <name>keyboardShortcut</name>
      <defaultValue>ctrl+alt+a</defaultValue>
      <label>Keyboard shortcut</label>
      <label lang="de-DE">Tastenkürzel</label>
      <helpText>Shortcut to open the widget (e.g. ctrl+alt+a). Empty disables it.</helpText>
      <helpText lang="de-DE">Tastenkürzel zum Öffnen (z. B. ctrl+alt+a). Leer = deaktiviert.</helpText>
    </input-field>

    <input-field type="text">
      <name>storageKey</name>
      <defaultValue>accessibility-widget</defaultValue>
      <label>Storage key</label>
      <label lang="de-DE">Speicher-Schlüssel</label>
      <helpText>localStorage key for saved visitor preferences. Change only to avoid conflicts.</helpText>
      <helpText lang="de-DE">localStorage-Schlüssel für gespeicherte Einstellungen. Nur bei Konflikten ändern.</helpText>
    </input-field>

    <input-field type="bool">
      <name>hidePoweredBy</name>
      <defaultValue>false</defaultValue>
      <label>Hide &quot;powered by&quot;</label>
      <label lang="de-DE">„Powered by“ ausblenden</label>
      <helpText>Hide the provider credit in the widget panel.</helpText>
      <helpText lang="de-DE">Den Anbieter-Hinweis im Widget ausblenden.</helpText>
    </input-field>

    <input-field type="bool">
      <name>debug</name>
      <defaultValue>false</defaultValue>
      <label>Debug logging</label>
      <label lang="de-DE">Debug-Protokollierung</label>
