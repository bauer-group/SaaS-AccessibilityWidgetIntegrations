<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/shopware/platform/trunk/src/Core/System/SystemConfig/Schema/config.xsd">
  <card>
    <title>Appearance</title>
    <title lang="de-DE">Darstellung</title>

    <input-field type="single-select">
      <name>position</name>
      <defaultValue>bottom-right</defaultValue>
      <label>Position</label>
      <label lang="de-DE">Position</label>
      <helpText>Where the floating button appears.</helpText>
      <helpText lang="de-DE">Wo die Schaltfläche erscheint.</helpText>
      <options>
        <option><id>bottom-right</id><name>bottom-right</name></option>
        <option><id>bottom-left</id><name>bottom-left</name></option>
        <option><id>top-right</id><name>top-right</name></option>
        <option><id>top-left</id><name>top-left</name></option>
      </options>
    </input-field>

    <input-field type="int">
      <name>offsetX</name>
      <defaultValue>20</defaultValue>
      <label>Horizontal offset (px)</label>
      <label lang="de-DE">Horizontaler Abstand (px)</label>
      <helpText>Distance from the screen edge.</helpText>
      <helpText lang="de-DE">Abstand zum Bildschirmrand.</helpText>
    </input-field>

    <input-field type="int">
      <name>offsetY</name>
      <defaultValue>20</defaultValue>
      <label>Vertical offset (px)</label>
      <label lang="de-DE">Vertikaler Abstand (px)</label>
      <helpText>Distance from the screen edge.</helpText>
      <helpText lang="de-DE">Abstand zum Bildschirmrand.</helpText>
    </input-field>

    <input-field type="int">
      <name>zIndex</name>
      <defaultValue>2147483646</defaultValue>
      <label>z-index</label>
      <label lang="de-DE">z-index</label>
      <helpText>Stacking order of the widget. Increase if it sits behind other elements.</helpText>
      <helpText lang="de-DE">Stapelreihenfolge des Widgets. Erhöhen, falls es hinter anderen Elementen liegt.</helpText>
    </input-field>

    <input-field type="colorpicker">
      <name>primaryColor</name>
      <defaultValue>#0058a3</defaultValue>
      <label>Brand color</label>
      <label lang="de-DE">Markenfarbe</label>
      <helpText>Color of the floating button.</helpText>
      <helpText lang="de-DE">Farbe der Schaltfläche.</helpText>
    </input-field>

